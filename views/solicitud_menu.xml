<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Acciones para Categorías -->
    <record id="action_gestion_solicitudes_categoria" model="ir.actions.act_window">
        <field name="name">Categorías</field>
        <field name="res_model">gestion_solicitudes.categoria</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea la primera categoría</p>
        </field>
    </record>

    <!-- Acciones para Solicitudes -->
    <record id="action_gestion_solicitudes_solicitud" model="ir.actions.act_window">
        <field name="name">Solicitudes</field>
        <field name="res_model">gestion_solicitudes.solicitud</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Crea la primera solicitud</p>
        </field>
    </record>
    <!-- Menú principal -->
    <menuitem id="menu_gestion_solicitudes_root"
             name="Gestión de Solicitudes"
             sequence="100"
             web_icon="gestion_solicitudes,static/description/icon.png"/>

    <!-- Categorías -->
    <menuitem id="menu_gestion_solicitudes_categorias"
             name="Categorías"
             parent="menu_gestion_solicitudes_root"
             action="action_gestion_solicitudes_categoria"
             sequence="10"/>

    <!-- Solicitudes -->
    <menuitem id="menu_gestion_solicitudes_solicitudes"
             name="Solicitudes"
             parent="menu_gestion_solicitudes_root"
             action="action_gestion_solicitudes_solicitud"
             sequence="20"/>

</odoo>